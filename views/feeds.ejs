

<%- include("./partials/head.ejs") %>

    <body>
        <%- include("./partials/header.ejs") %>

            <main>
                
                <div class="wrapper">
                    <section class="content">
                        <div class="add-post">
                            <a class="add-post__link link row f-center" href="/posts/create-post">
                                New
                                Post
                                <img src="/images//icons//material-symbols--add-notes.svg" alt="">
                            </a>
                        </div>

                        <section class="posts">
                            <%- include("./partials/posts.ejs") %>
                                <div class="pagination">
                                    <ul class="pag-list">
                                        <li class="pag-item">
                                            <% if (pageCount> 1){ %>
                                                <% for (let i=1; i < pageCount + 1; i++){ %>
                                                    <a href="/posts/feeds?p=<%= i %>" class="pag-link">
                                                        <%=i%>
                                                    </a>
                                                    <% }%>
                                                        <% }%>
                                        </li>
                                    </ul>
                                </div>
                        </section>
                    </section>
                </div>

            </main>
        <%- include("./partials/footer.ejs") %>
           
    </body>

</html>