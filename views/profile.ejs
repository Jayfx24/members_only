<%- include("./partials/head.ejs") %>

    <body>
        <%- include("./partials/header.ejs") %>
            <main>
                <section class="wrapper">
                    <div class="add-post">
                        <a class="add-post__link link row f-center padding-inline-500" href="/posts/create-post">
                            New Post
                            <img src="/images//icons//material-symbols--add-notes.svg" alt="">
                        </a>
                    </div>
                    <div class="row gap-sm height-100">
                        <article class="user-profile col padding-inline-700 padding-block-500 border gap">
                            <div class="user__info col g-center">
                                <div class="avatar row f-center g-center">
                                    <h1 class="user__initials"><%= currentUser.first_name[0] %>.<%= currentUser.last_name[0] %></h1>
                                </div>
                                <h2 class="fullname">
                                    <%=profile.first_name|| undefined %>
                                        <%=profile.last_name|| undefined %>
                                </h2>
                                <p class="username">@<%= profile.username %>
                                </p>
                            </div>
                            <ul class="user__details col gap-sm">
                                <li class="detail">
                                    <p>Post count : <span class="">
                                            <%= postsLength || 0 %>
                                        </span></p>
                                </li>
                                <li class="detail">
                                    <p>Joined : <span class="">
                                            <%= new Date(profile.created_at).toDateString() %>
                                        </span></p>
                                </li>
                                <% if (profile.member) { %>
                                    <li class="detail">
                                        <p>Member since : <span class="">
                                                <%=new Date(profile.member_since).toLocaleTimeString()%> ,
                                                    <%=new Date(profile.member_since).toDateString()%>
                                            </span></p>
                                    </li>
                                    <% } %>

                                        
                            </ul>

                            <% if (currentUser.member && !currentUser.admin) { %>
                                <a href="/<%= currentUser.id %>/admin" class="row f-center"> <img
                                        src="/images/icons/material-symbols--admin-panel-settings.svg"
                                        alt="Become our admin"> Become our admin</a>
                                <% } %>
                                     <span class="row f-center gap">
                                         <% if (currentUser.member) { %>
                                                        <span class="member row f-center"> <img
                                                                src="/images/icons/material-symbols--card-membership.svg"
                                                                alt="Member">Member</span>
                                         
                                                    <% } %>
                                                                             <% if (currentUser.admin) {%>
                                            <span class="admin row f-center"> <img
                                                    src="/images/icons/material-symbols--admin-panel-settings.svg"
                                                    alt="Admin">Admin</span>
                                            <% } %>
                                     </span>

                                           
                        </article>
                        <section class="user__posts f-col padding-inline-500">
                            <%- include("./partials/posts.ejs") %>
                                <div class="pagination">
                                    <ul class="pag-list row gap-sm g-center">
                                        <li class="pag-item">
                                            <% if (pageCount> 1){ %>
                                                <% for (let i=1; i < pageCount + 1; i++){ %>
                                                    <a href="/user/profile/feeds?p=<%= i %>" class="pag-link">
                                                        <%=i%>
                                                    </a>
                                                    <% }%>
                                                        <% }%>
                                        </li>
                                    </ul>
                                </div>
                        </section>
                    </div>
                </section>
            </main>
    </body>
    <%- include("./partials/footer.ejs") %>

        </html>