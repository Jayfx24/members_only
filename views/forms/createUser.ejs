<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
</head>

<body>

    <%- include("../partials/error.ejs") %>
        <form action="" method="post">
            <div class="form-groups">
                <div class="row">
                    <div class="form-group">
                        <label for="fn">First Name:</label>
                        <input type="text" name="fn" value="<%=locals.data?.fn%>" required>
                    </div>
                    <div class="form-group">
                        <label for="ln">Last Name:</label>
                        <input type="text" name="ln" value="<%=locals.data?.ln%>" required>
                    </div>
                </div>
                <div class="form-group">
                    <label for="username">Username: </label>
                    <input type="text" name="username"  value="<%=locals.data?.username%>" required>
                </div>
                <div class="form-group">
                    <label for="pwd">Password:</label>
                    <input type="password" name="pwd" required>
                </div>
                <div class="form-group">
                    <label for="cPwd">Confirm Password:</label>
                    <input type="password" name="cPwd" required>
                </div>

            </div>
            <button type="submit">Submit</button>

        </form>

</body>

</html>